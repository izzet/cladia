!globals/epoch/.gitkeep
!globals/epoch/datasets/
!globals/epoch/datasets/.gitkeep
!globals/epoch/models/
!globals/epoch/models/.gitkeep
results/**
!results/.gitkeep
!results/repro/
!results/repro/.gitkeep
!results/repro_compare/
!results/repro_compare/.gitkeep
!results/repro_analysis_outputs/
!results/repro_analysis_outputs/.gitkeep
logs/
outputs/
tmp/
*.bak
